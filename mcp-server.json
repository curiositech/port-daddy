{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "port-daddy",
  "version": "3.5.0",
  "description": "Authoritative port manager and multi-agent coordination for local development. 44 tools for port assignment, sessions, locks, pub/sub, agent registry, DNS, briefing, and integration signals.",
  "homepage": "https://github.com/curiositech/port-daddy",
  "repository": "https://github.com/curiositech/port-daddy",
  "license": "MIT",
  "author": "Curiositech",
  "transport": {
    "type": "stdio",
    "command": "pd",
    "args": ["mcp"]
  },
  "capabilities": {
    "tools": { "listChanged": false },
    "resources": {}
  },
  "tags": [
    "ports",
    "coordination",
    "agents",
    "sessions",
    "locks",
    "messaging",
    "dns",
    "briefing",
    "salvage"
  ]
}
